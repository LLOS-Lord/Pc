local discoveredRemotes = {}
local remoteCount = 0

-- Hàm hiển thị Remote tìm được lên bảng điều khiển
local function logDiscoveredRemote(remote, originLocation)
    if discoveredRemotes[remote] then return end
    discoveredRemotes[remote] = true
    remoteCount = remoteCount + 1
    
    StatusLabel.Text = "Tìm thấy: " .. tostring(remoteCount) .. " Remotes"

    local LogItem = Instance.new("TextButton")
    LogItem.Size = UDim2.new(1, -10, 0, 30)
    LogItem.BackgroundColor3 = remote:IsA("RemoteEvent") and Color3.fromRGB(30, 45, 35) or Color3.fromRGB(45, 30, 35)
    LogItem.Text = string.format(" [%s] -> %s", remote.ClassName == "RemoteEvent" and "EVENT" or "FUNC", tostring(remote.Name))
    LogItem.TextColor3 = Color3.fromRGB(255, 255, 255)
    LogItem.Font = Enum.Font.Arial
    LogItem.TextSize = 13
    LogItem.TextXAlignment = Enum.TextXAlignment.Left
    LogItem.Parent = ScrollingFrame

    -- Nhấp vào Remote để nhận code mẫu dùng để gửi/hack lệnh lên server
    LogItem.MouseButton1Click:Connect(function()
        print("\n=========================================")
        print(string.format("ĐƯỜNG DẪN REMOTE: %s", remote:GetFullName()))
        print(string.format("NƠI TÌM THẤY: %s", originLocation))
        print("-----------------------------------------")
        print("[MÃ CƠ BẢN ĐỂ KÍCH HOẠT THỬ (CODE MẪU)]:")
        
        if remote:IsA("RemoteEvent") then
            print(string.format("local remote = game:%s\nremote:FireServer(\"Điền tham số cần test tại đây\")", remote:GetFullName():sub(6)))
        else
            print(string.format("local remote = game:%s\nlocal result = remote:InvokeServer(\"Điền tham số cần test tại đây\")\nprint(result)", remote:GetFullName():sub(6)))
        end
        print("=========================================\n")
    end)
end

-- Vòng lặp quét tự động liên tục bộ nhớ ẩn (Deep Memory Scan)
task.spawn(function()
    while task.wait(1) do -- Tiến hành quét định kỳ mỗi giây một lần để tránh lag máy
        local targets = {game:GetService("ReplicatedStorage"), game:GetService("Workspace"), game:GetService("Players"), game:GetService("JointsService")}
        
        for _, location in ipairs(targets) do
            pcall(function()
                local objects = location:GetDescendants()
                for _, obj in ipairs(objects) do
                    if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                        logDiscoveredRemote(obj, location.Name)
                    end
                end
            </pcall>
        end
    end
end)

-- Kết hợp bổ sung bộ lắng nghe sự kiện phát sinh thời gian thực (Real-time Listener)
local oldNamecall
pcall(function()
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            task.defer(function(remote)
                if remote and typeof(remote) == "Instance" then
                    logDiscoveredRemote(remote, "Kích hoạt thời gian thực")
                end
            end, self)
        end
        return oldNamecall(self, ...)
    end)
end)

