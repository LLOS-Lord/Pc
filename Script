    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
end)

local cachedRemotes = {}
local totalFound = 0

local function insertRemoteToMenu(remote, sourceName)
    if cachedRemotes[remote] then return end
    cachedRemotes[remote] = true
    totalFound = totalFound + 1
    
    StatusLabel.Text = "Tổng: " .. tostring(totalFound) .. " Remotes"

    local LogItem = Instance.new("TextButton")
    LogItem.Size = UDim2.new(1, -10, 0, 30)
    LogItem.BackgroundColor3 = remote:IsA("RemoteEvent") and Color3.fromRGB(35, 45, 35) or Color3.fromRGB(45, 35, 35)
    LogItem.Text = string.format(" [%s] %s (%s)", remote.ClassName:sub(7):upper(), tostring(remote.Name), sourceName)
    LogItem.TextColor3 = Color3.fromRGB(255, 255, 255)
    LogItem.Font = Enum.Font.Arial
    LogItem.TextSize = 13
    LogItem.TextXAlignment = Enum.TextXAlignment.Left
    LogItem.Parent = ScrollingFrame

    LogItem.MouseButton1Click:Connect(function()
        print("\n=========================================")
        print("REMOTE:", remote:GetFullName())
        print("LOẠI:", remote.ClassName)
        print("MÃ THỰC THI GỢI Ý:")
        if remote:IsA("RemoteEvent") then
            print(string.format("game:%s:FireServer()", remote:GetFullName():sub(6)))
        else
            print(string.format("print(game:%s:InvokeServer())", remote:GetFullName():sub(6)))
        end
        print("=========================================\n")
    end)
end

-- Vòng lặp quét an toàn không gây crash luồng dữ liệu
task.spawn(function()
    while task.wait(1) do
        local pathways = {game:GetService("ReplicatedStorage"), game:GetService("Workspace")}
        for _, path in ipairs(pathways) do
            pcall(function()
                local children = path:GetDescendants()
                for _, item in ipairs(children) do
                    if item:IsA("RemoteEvent") or item:IsA("RemoteFunction") then
                        insertRemoteToMenu(item, "SCAN")
                    end
                end
            end)
        end
    end
end)

-- Đồng bộ thêm bộ lắng nghe Namecall trực tiếp
local oldNamecall
pcall(function()
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            task.defer(function(obj)
                if obj and typeof(obj) == "Instance" then
                    insertRemoteToMenu(obj, "LIVE")
                end
            end, self)
        end
        return oldNamecall(self, ...)
    end)
end)

print("[SimpleSpy-V9] Menu sửa lỗi hiển thị đã được khởi chạy thành công.")
