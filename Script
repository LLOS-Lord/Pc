local logCount = 0
local function displayLogWithTraceback(remote, method, args, callingScript, traceInfo)
    if not remote or not remote.Name then return end
    logCount = logCount + 1
    
    local LogItem = Instance.new("TextButton")
    LogItem.Size = UDim2.new(1, -10, 0, 30)
    LogItem.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    LogItem.Text = string.format(" [%d] [%s] -> %s", logCount, method, tostring(remote.Name))
    LogItem.TextColor3 = Color3.fromRGB(0, 255, 150)
    LogItem.Font = Enum.Font.Arial
    LogItem.TextSize = 13
    LogItem.TextXAlignment = Enum.TextXAlignment.Left
    LogItem.Parent = ScrollingFrame

    LogItem.MouseButton1Click:Connect(function()
        print("\n=========================================")
        print(string.format("REMOTE: %s", remote:GetFullName()))
        print(string.format("PHƯƠNG THỨC: %s", method))
        
        -- Hiển thị script gọi lệnh
        if callingScript then
            print(string.format("SCRIPT KÍCH HOẠT: %s", callingScript:GetFullName()))
        else
            print("SCRIPT KÍCH HOẠT: Không xác định (Có thể gọi từ Core hoặc gọi ngầm)")
        end
        
        -- Hiển thị chi tiết vị trí dòng code (Traceback)
        print("\n[VỊ TRÍ DÒNG MÃ TRONG BỘ NHỚ]:")
        print(traceInfo or "Không thể trích xuất dòng mã.")
        
        print("\nTHAM SỐ TRUYỀN VÀO:")
        if args and #args > 0 then
            for i, v in pairs(args) do
                print(string.format("  [%s]: %s (%s)", tostring(i), tostring(v), typeof(v)))
            end
        else
            print("  (Trống)")
        end
        print("=========================================\n")
    end)
end

-- Tiến hành Hook metamethod hệ thống để lấy thông tin môi trường script đang chạy (Environment)
local oldNamecall
pcall(function()
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            local args = {...}
            
            -- Lấy đối tượng Script đang thực hiện cuộc gọi hiện tại
            local callingScript = getcallingscript and getcallingscript() or nil
            
            -- Trích xuất lịch sử ngăn xếp dòng lệnh đang chạy
            local traceInfo = debug.traceback("Luồng thực thi mã nguồn:")
            
            task.defer(displayLogWithTraceback, self, method, args, callingScript, traceInfo)
        end
        return oldNamecall(self, ...)
    end)
end)

