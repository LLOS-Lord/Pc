local remoteLogs = {}
local uiElements = {}

local function formatValue(val)
    local t = typeof(val)
    if t == "string" then return '"' .. val .. '"'
    elseif t == "number" or t == "boolean" then return tostring(val)
    elseif t == "Vector3" then return string.format("Vector3.new(%f, %f, %f)", val.X, val.Y, val.Z)
    elseif t == "CFrame" then return string.format("CFrame.new(%s)", tostring(val))
    elseif t == "Instance" then return "game." .. val:GetFullName()
    elseif t == "table" then
        local str = "{\n"
        for k, v in pairs(val) do
            local keyStr = typeof(k) == "number" and "" or string.format("[%s] = ", formatValue(k))
            str = str .. "        " .. keyStr .. formatValue(v) .. ",\n"
        end
        return str .. "    }"
    else return "nil --[[" .. t .. "]]" end
end

local function generateScriptText(remote, data)
    local code = "[[ CODE GENERATED BY SIMPLE SPY ]]\n\n"
    code = code .. string.format("local Remote = game:%s\n\n", remote:GetFullName():sub(6))
    code = code .. "local Arguments = {\n"
    if data.args and #data.args > 0 then
        for i, arg in ipairs(data.args) do
            code = code .. string.format("    [%d] = %s,\n", i, formatValue(arg))
        end
    else
        code = code .. "    -- Không có tham số được gửi\n"
    end
    code = code .. "}\n\n"
    if data.method == "FireServer" then
        code = code .. "Remote:FireServer(unpack(Arguments))"
    else
        code = code .. "local success, response = pcall(function()\n"
        code = code .. "    return Remote:InvokeServer(unpack(Arguments))\n"
        code = code .. "end)\n"
        code = code .. "print('Response:', response)"
    end
    return code
end

local function updateRemoteUI(remote, method, args)
    if not remote or not remote.Name then return end
    
    remoteLogs[remote] = {method = method, args = args}
    
    if uiElements[remote] then return end

    local LogItem = Instance.new("TextButton")
    LogItem.Size = UDim2.new(1, -10, 0, 30)
    LogItem.BackgroundColor3 = method == "FireServer" and Color3.fromRGB(30, 42, 35) or Color3.fromRGB(42, 30, 35)
    LogItem.BorderSizePixel = 0
    LogItem.Text = string.format(" [%s] %s", method:sub(1,4):upper(), tostring(remote.Name))
    LogItem.TextColor3 = Color3.fromRGB(240, 240, 240)
    LogItem.Font = Enum.Font.Arial
    LogItem.TextSize = 12
    LogItem.TextXAlignment = Enum.TextXAlignment.Left
    LogItem.Parent = ScrollingFrame
    
    uiElements[remote] = LogItem

    LogItem.MouseButton1Click:Connect(function()
        local data = remoteLogs[remote]
        if data then
            -- Tạo mã nguồn giả lập và nạp trực tiếp vào ô văn bản trên UI
            CodeTextBox.Text = generateScriptText(remote, data)
        end
    end)
end

-- Bộ quét tĩnh đồng bộ danh sách ban đầu
task.spawn(function()
    local pathways = {game:GetService("ReplicatedStorage"), game:GetService("Workspace")}
    for _, path in ipairs(pathways) do
        pcall(function()
            for _, item in ipairs(path:GetDescendants()) do
                if item:IsA("RemoteEvent") then updateRemoteUI(item, "FireServer", {})
                elseif item:IsA("RemoteFunction") then updateRemoteUI(item, "InvokeServer", {}) end
            end
        end)
    end
end)

-- Trình chặn thời gian thực cập nhật đối số chính xác khi nhấn nút/thao tác game
local oldNamecall
pcall(function()
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            local args = {...}
            task.defer(updateRemoteUI, self, method, args)
        end
        return oldNamecall(self, ...)
    end)
end)

