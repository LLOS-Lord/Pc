-- Hàm thêm bản ghi từ Remote vào UI
local logCount = 0
local function addLogToUI(remote, method, args)
    logCount = logCount + 1
    
    local LogButton = Instance.new("TextButton")
    LogButton.Size = UDim2.new(1, -10, 0, 25)
    LogButton.BackgroundColor3 = method == "FireServer" and Color3.fromRGB(40, 50, 65) or Color3.fromRGB(65, 45, 45)
    LogButton.Text = string.format(" [%d] [%s] -> %s", logCount, method, remote.Name)
    LogButton.TextColor3 = Color3.fromRGB(230, 230, 230)
    LogButton.Font = Enum.Font.SourceSans
    LogButton.TextSize = 14
    LogButton.TextXAlignment = Enum.TextXAlignment.Left
    LogButton.Parent = ScrollingFrame

    -- Click vào dòng Log để in chi tiết tham số (arguments) ra F9 Console
    LogButton.MouseButton1Click:Connect(function()
        print(string.format("--- CHI TIẾT REMOTE: %s ---", remote:GetFullName()))
        print("Phương thức:", method)
        if #args > 0 then
            for i, arg in ipairs(args) do
                print(string.format("Tham số [%d]: %s (%s)", i, tostring(arg), typeof(arg)))
            end
        else
            print("Tham số: Không có (Empty)")
        end
        print("---------------------------------------")
    end)
    
    -- Giới hạn số lượng hiển thị trên UI để tránh lag game (Tối đa 50 dòng)
    local children = ScrollingFrame:GetChildren()
    if #children > 51 then
        for i = 1, (#children - 51) do
            if children[i]:IsA("TextButton") then
                children[i]:Destroy()
            end
        end
    end
end

-- ====================================================================
-- HỆ THỐNG HOOK NỀN CẤP THẤP (BYPASS CHẶN REMOTE TRONG BLOX LOOT)
-- ====================================================================
local oldFireServer
local oldInvokeServer

-- Ép ghi nhận log bất kể kịch bản bảo mật của trò chơi
local function processLog(self, method, args)
    if typeof(self) == "Instance" then
        task.spawn(addLogToUI, self, method, args)
    end
end

-- Tiến hành đè (Hook) dữ liệu truyền tải của Roblox
oldFireServer = hookfunction(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
    local args = {...}
    processLog(self, "FireServer", args)
    return oldFireServer(self, ...)
end))

oldInvokeServer = hookfunction(Instance.new("RemoteFunction").InvokeServer, newcclosure(function(self, ...)
    local args = {...}
    processLog(self, "InvokeServer", args)
    return oldInvokeServer(self, ...)
end))

-- Hỗ trợ thêm bộ quét qua Metamethod __namecall để bắt triệt để luồng lệnh ẩn
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if method == "FireServer" or method == "InvokeServer" then
        processLog(self, method, args)
    end
    return oldNamecall(self, ...)
end)

