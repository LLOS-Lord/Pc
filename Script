-- BLOX LOOT ULTIMATE HACK (V9.0 - FIXED ALL)
-- Fix: phân biệt NPC nhiệm vụ & quái, auto loot teleport, fly di chuyển, tầm nhìn rộng
-- =============================================
if not game:IsLoaded() then game.Loaded:Wait() end

local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local userInput = game:GetService("UserInputService")
local runService = game:GetService("RunService")
local camera = workspace.CurrentCamera

-- =============================================
-- THAM CHIẾU NHÂN VẬT (cập nhật khi respawn)
-- =============================================
local function getChar()
    return player.Character or player.CharacterAdded:Wait()
end

local character = getChar()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- =============================================
-- BẢNG TRẠNG THÁI TOÀN CỤC
-- =============================================
local state = {
    autoFarm = false,
    autoCollect = false,
    collectMode = "Teleport", -- "Near" hoặc "Teleport"
    hitbox = false,
    multiDamage = false,
    fly = false,
    desync = false,
    menuVisible = true,
    speed = 50,
    jump = 80,
    farmRadius = 40,
    collectRadius = 100  -- Tăng tầm nhìn auto loot lên 100
}

-- Các biến điều khiển vòng lặp
local farmLoop = nil
local collectLoop = nil
local hitboxLoop = nil
local damageLoop = nil
local flyConnection = nil
local flyBodyPosition = nil
local flyBodyGyro = nil

-- =============================================
-- HÀM TIỆN ÍCH CẬP NHẬT THAM CHIẾU
-- =============================================
local function updateCharacter()
    character = getChar()
    humanoid = character:FindFirstChild("Humanoid")
    rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then
        character = player.CharacterAdded:Wait()
        humanoid = character:WaitForChild("Humanoid")
        rootPart = character:WaitForChild("HumanoidRootPart")
    end
end
player.CharacterAdded:Connect(updateCharacter)

-- =============================================
-- 1. TÌM NPC QUÁI (chỉ quái, không bao gồm NPC nhiệm vụ)
-- =============================================
local function isQuestNPC(model)
    -- Kiểm tra nếu là NPC nhiệm vụ
    if not model or not model:IsA("Model") then return false end
    local name = model.Name:lower()
    -- NPC nhiệm vụ thường có tên chứa các từ này
    if name:find("npc") or name:find("quest") or name:find("shop") or name:find("merchant") or name:find("trader") then
        return true
    end
    -- NPC nhiệm vụ thường không có thanh máu hoặc máu vô hạn
    local hum = model:FindFirstChild("Humanoid")
    if hum and hum.MaxHealth > 999999 then
        return true
    end
    -- Kiểm tra nếu có ProximityPrompt (thường là NPC tương tác)
    if model:FindFirstChildOfClass("ProximityPrompt") then
        return true
    end
    return false
end

local function isMob(model)
    -- Kiểm tra nếu là quái (có thể tấn công)
    if not model or not model:IsA("Model") then return false end
    if isQuestNPC(model) then return false end
    local name = model.Name:lower()
    -- Quái thường có tên chứa các từ này
    if name:find("mob") or name:find("enemy") or name:find("boss") or name:find("zombie") or name:find("skeleton") or name:find("goblin") or name:find("orc") or name:find("slime") or name:find("wolf") or name:find("bear") or name:find("bandit") then
        return true
    end
    -- Kiểm tra Humanoid: quái có máu giới hạn và có thể bị tấn công
    local hum = model:FindFirstChild("Humanoid")
    if hum and hum.MaxHealth > 0 and hum.MaxHealth < 999999 then
        return true
    end
    return false
end

local function getClosestMob(radius)
    radius = radius or state.farmRadius
    local closest = nil
    local shortest = radius^2
    local pos = rootPart.Position
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            -- Bỏ qua người chơi
            if not game.Players:GetPlayerFromCharacter(obj) then
                -- Chỉ chọn quái, bỏ qua NPC nhiệm vụ
                if isMob(obj) then
                    local hum = obj:FindFirstChild("Humanoid")
                    if hum and hum.Health > 0 then
                        local targetRoot = obj:FindFirstChild("HumanoidRootPart")
                        if targetRoot then
                            local distSq = (pos - targetRoot.Position).Magnitude^2
                            if distSq < shortest then
                                shortest = distSq
                                closest = obj
                            end
                        end
                    end
                end
            end
        end
    end
    return closest
end

-- =============================================
-- 2. TÌM LOOT (vật phẩm rơi) - Tăng tầm nhìn lên 100
-- =============================================
local function getLootItems(radius)
    radius = radius or state.collectRadius
    local items = {}
    local pos = rootPart.Position
    -- Tìm các Model có tên chứa "Loot", "Chest", "Box", "Drop", "Item"
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local name = obj.Name:lower()
            if name:find("loot") or name:find("chest") or name:find("box") or name:find("drop") or name:find("item") or name:find("coin") or name:find("gem") or name:find("crate") then
                local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("RootPart") or obj:FindFirstChildOfClass("BasePart")
                if root then
                    local dist = (pos - root.Position).Magnitude
                    if dist < radius then
                        table.insert(items, obj)
                    end
                end
            end
        end
        -- Nếu không tìm thấy Model, thử tìm Part có tên chứa "loot"
        if #items == 0 and obj:IsA("BasePart") then
            local name = obj.Name:lower()
            if name:find("loot") or name:find("chest") or name:find("drop") or name:find("coin") then
                local dist = (pos - obj.Position).Magnitude
                if dist < radius then
                    table.insert(items, obj)
                end
            end
        end
    end
    return items
end

-- =============================================
-- 3. AUTO FARM (chỉ tấn công quái, bỏ qua NPC nhiệm vụ)
-- =============================================
local function startAutoFarm()
    if farmLoop then return end
    farmLoop = runService.Heartbeat:Connect(function()
        if not state.autoFarm then return end
        local target = getClosestMob(state.farmRadius)
        if target and target:FindFirstChild("HumanoidRootPart") then
            local targetRoot = target.HumanoidRootPart
            humanoid:MoveTo(targetRoot.Position)
            local dist = (rootPart.Position - targetRoot.Position).Magnitude
            if dist < 10 then
                -- Tấn công bằng tất cả tool
                for _, tool in ipairs(character:GetChildren()) do
                    if tool:IsA("Tool") then
                        tool:Activate()
                        task.wait(0.15)
                    end
                end
            end
        end
    end)
end

local function stopAutoFarm()
    if farmLoop then farmLoop:Disconnect() farmLoop = nil end
end

-- =============================================
-- 4. AUTO COLLECT (2 chế độ: Near và Teleport)
-- =============================================
local function startAutoCollect()
    if collectLoop then return end
    collectLoop = runService.Heartbeat:Connect(function()
        if not state.autoCollect then return end
        local loots = getLootItems(state.collectRadius)
        for _, loot in ipairs(loots) do
            if loot:IsA("Model") then
                local root = loot:FindFirstChild("HumanoidRootPart") or loot:FindFirstChild("RootPart") or loot:FindFirstChildOfClass("BasePart")
                if root then
                    local dist = (rootPart.Position - root.Position).Magnitude
                    -- Chế độ Teleport: dịch chuyển đến loot
                    if state.collectMode == "Teleport" then
                        rootPart.CFrame = CFrame.new(root.Position + Vector3.new(0, 2, 0))
                        task.wait(0.1)
                    else
                        -- Chế độ Near: di chuyển đến gần
                        humanoid:MoveTo(root.Position)
                        task.wait(0.1)
                    end
                    -- Kích hoạt ProximityPrompt nếu có
                    local prompt = loot:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then
                        prompt:InputHoldBegin(player)
                        task.wait(0.2)
                        prompt:InputHoldEnd(player)
                    else
                        -- Nếu không có prompt, thử chạm vào loot
                        rootPart.CFrame = CFrame.new(root.Position + Vector3.new(0, 1, 0))
                        task.wait(0.05)
                    end
                end
            elseif loot:IsA("BasePart") then
                local dist = (rootPart.Position - loot.Position).Magnitude
                if state.collectMode == "Teleport" then
                    rootPart.CFrame = CFrame.new(loot.Position + Vector3.new(0, 2, 0))
                    task.wait(0.1)
                else
                    humanoid:MoveTo(loot.Position)
                    task.wait(0.1)
                end
                rootPart.CFrame = CFrame.new(loot.Position + Vector3.new(0, 1, 0))
                task.wait(0.05)
            end
        end
    end)
end

local function stopAutoCollect()
    if collectLoop then collectLoop:Disconnect() collectLoop = nil end
end

-- =============================================
-- 5. HITBOX EXPANSION (x3 kích thước)
-- =============================================
local function startHitbox()
    if hitboxLoop then return end
    hitboxLoop = runService.Heartbeat:Connect(function()
        if not state.hitbox then return end
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name:lower():find("hitbox") or obj.Name:lower():find("handle") or obj.Name:lower():find("head") or obj.Name:lower():find("torso")) then
                local size = obj.Size
                obj.Size = Vector3.new(size.X * 3, size.Y * 3, size.Z * 3)
            end
        end
    end)
end

local function stopHitbox()
    if hitboxLoop then hitboxLoop:Disconnect() hitboxLoop = nil end
end

-- =============================================
-- 6. MULTI DAMAGE (kích hoạt nhiều tool)
-- =============================================
local function startMultiDamage()
    if damageLoop then return end
    damageLoop = runService.Heartbeat:Connect(function()
        if not state.multiDamage then return end
        for _, tool in ipairs(character:GetChildren()) do
            if tool:IsA("Tool") then
                tool:Activate()
                task.wait(0.15)
            end
        end
    end)
end

local function stopMultiDamage()
    if damageLoop then damageLoop:Disconnect() damageLoop = nil end
end

-- =============================================
-- 7. FLY (dùng BodyPosition + BodyGyro - di chuyển mượt mà)
-- =============================================
local function startFly()
    if flyConnection then return end
    state.fly = true
    
    -- Tạo BodyPosition để giữ vị trí
    flyBodyPosition = Instance.new("BodyPosition")
    flyBodyPosition.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    flyBodyPosition.P = 5000
    flyBodyPosition.D = 1000
    flyBodyPosition.Position = rootPart.Position
    flyBodyPosition.Parent = rootPart
    
    -- Tạo BodyGyro để giữ hướng
    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    flyBodyGyro.CFrame = rootPart.CFrame
    flyBodyGyro.P = 5000
    flyBodyGyro.D = 1000
    flyBodyGyro.Parent = rootPart
    
    local speed = 60
    local cam = camera
    
    flyConnection = runService.Heartbeat:Connect(function()
        if not state.fly or not flyBodyPosition or not flyBodyGyro then
            stopFly()
            return
        end
        -- Lấy hướng camera
        local forward = cam.CFrame.LookVector
        forward = Vector3.new(forward.X, 0, forward.Z).Unit
        local right = cam.CFrame.RightVector
        right = Vector3.new(right.X, 0, right.Z).Unit
        
        local move = Vector3.new(0, 0, 0)
        if userInput:IsKeyDown(Enum.KeyCode.W) then move = move + forward end
        if userInput:IsKeyDown(Enum.KeyCode.S) then move = move - forward end
        if userInput:IsKeyDown(Enum.KeyCode.A) then move = move - right end
        if userInput:IsKeyDown(Enum.KeyCode.D) then move = move + right end
        if userInput:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
        if userInput:IsKeyDown(Enum.KeyCode.LeftControl) then move = move - Vector3.new(0, 1, 0) end
        
        if move.Magnitude > 0 then
            local targetPos = rootPart.Position + move.Unit * speed * 0.1
            flyBodyPosition.Position = targetPos
        else
            flyBodyPosition.Position = rootPart.Position
        end
        flyBodyGyro.CFrame = rootPart.CFrame
    end)
end

local function stopFly()
    state.fly = false
    if flyConnection then flyConnection:Disconnect() flyConnection = nil end
    if flyBodyPosition then flyBodyPosition:Destroy() flyBodyPosition = nil end
    if flyBodyGyro then flyBodyGyro:Destroy() flyBodyGyro = nil end
end

local function toggleFly()
    if state.fly then stopFly() else startFly() end
end

-- =============================================
-- 8. DESYNC BODY (tàng hình)
-- =============================================
local function toggleDesync()
    state.desync = not state.desync
    if state.desync then
        character:BreakJoints()
        player.CharacterAdded:Wait()
        updateCharacter()
    end
end

-- =============================================
-- 9. TELEPORT TO LOOT (dịch chuyển đến loot gần nhất)
-- =============================================
local function teleportToLoot()
    local loots = getLootItems(200)
    if #loots > 0 then
        local target = loots[1]
        local pos
        if target:IsA("Model") then
            local root = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("RootPart") or target:FindFirstChildOfClass("BasePart")
            if root then pos = root.Position else return end
        else
            pos = target.Position
        end
        rootPart.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
    end
end

