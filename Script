-- Biến đếm và xử lý Log dữ liệu
local totalLogs = 0
local function outputToScreen(remote, method, args)
    if not remote or not remote.Name then return end
    totalLogs = totalLogs + 1
    
    local Item = Instance.new("TextButton")
    Item.Size = UDim2.new(1, -5, 0, 30)
    Item.BackgroundColor3 = method == "FireServer" and Color3.fromRGB(45, 55, 70) or Color3.fromRGB(70, 50, 50)
    Item.BorderSizePixel = 0
    Item.Text = string.format(" [%d] [%s] -> %s", totalLogs, method, tostring(remote.Name))
    Item.TextColor3 = Color3.fromRGB(255, 255, 255)
    Item.Font = Enum.Font.SourceSansSemibold
    Item.TextSize = 14
    Item.TextXAlignment = Enum.TextXAlignment.Left
    Item.Parent = ScrollingFrame

    -- Khi nhấn vào hàng log, chi tiết tham số sẽ in ra cửa sổ F9 lập tức
    Item.MouseButton1Click:Connect(function()
        print("\n=== THÔNG TIN CHI TIẾT REMOTE BỊ CHẶN ===")
        print("Tên đường dẫn:", remote:GetFullName())
        print("Loại phương thức:", method)
        print("Dữ liệu gửi lên:")
        for i, v in pairs(args) do
            print(string.format("   Tham số [%s]: %s (%s)", tostring(i), tostring(v), typeof(v)))
        end
        print("=========================================\n")
    end)
    
    -- Tự động dọn dẹp các log cũ để tránh quá tải bộ nhớ gây lag thiết bị
    local currentLogs = ScrollingFrame:GetChildren()
    if #currentLogs > 40 then
        for i = 1, (#currentLogs - 40) do
            if currentLogs[i]:IsA("TextButton") then
                currentLogs[i]:Destroy()
            end
        end
    end
end

-- ====================================================================
-- BỘ LỌC HOOK AN TOÀN TRÁNH CRASH EXECUTOR
-- ====================================================================
local successHook, oldNamecall
successHook, _ = pcall(function()
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        if method == "FireServer" or method == "InvokeServer" then
            task.defer(outputToScreen, self, method, args)
        end
        return oldNamecall(self, ...)
    end)
end)

-- Phương pháp dự phòng 2: Nếu Metamethod lỗi, chèn trực tiếp vào hàm Instance gốc
if not successHook or not oldNamecall then
    pcall(function()
        local oldFire = Instance.new("RemoteEvent").FireServer
        hookfunction(oldFire, newcclosure(function(self, ...)
            task.defer(outputToScreen, self, "FireServer", {...})
            return oldFire(self, ...)
        end))
        
        local oldInvoke = Instance.new("RemoteFunction").InvokeServer
        hookfunction(oldInvoke, newcclosure(function(self, ...)
            task.defer(outputToScreen, self, "InvokeServer", {...})
            return oldInvoke(self, ...)
        end))
    end)
end

print("[SimpleSpy-V5] Đã tải thành công giao diện tại PlayerGui.")
