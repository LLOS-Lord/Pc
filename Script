-- Hàm định dạng kiểu dữ liệu sang chuỗi ký tự hợp lệ trong mã nguồn Luau
local function formatValue(val)
    local t = typeof(val)
    if t == "string" then
        return '"' .. val .. '"'
    elseif t == "number" or t == "boolean" then
        return tostring(val)
    elseif t == "Vector3" then
        return string.format("Vector3.new(%f, %f, %f)", val.X, val.Y, val.Z)
    elseif t == "CFrame" then
        return string.format("CFrame.new(%s)", tostring(val))
    elseif t == "Instance" then
        return "game." .. val:GetFullName()
    elseif t == "table" then
        local str = "{\n"
        for k, v in pairs(val) do
            local keyStr = typeof(k) == "number" and "" or string.format("[%s] = ", formatValue(k))
            str = str .. "        " .. keyStr .. formatValue(v) .. ",\n"
        end
        str = str .. "    }"
        return str
    else
        return "nil --[[" .. t .. "]]"
    end
end

-- Hàm cập nhật hoặc thêm mới bản ghi lên giao diện
local function updateRemoteUI(remote, method, args)
    if not remote or not remote.Name then return end
    
    -- Lưu trữ lịch sử dữ liệu mới nhất của Remote này
    remoteLogs[remote] = {
        method = method,
        args = args,
        time = os.date("%X")
    }
    
    -- Nếu đã có nút trên giao diện rồi thì đổi màu nổi bật báo hiệu có dữ liệu mới, không tạo trùng lặp
    if uiElements[remote] then
        uiElements[remote].BackgroundColor3 = Color3.fromRGB(0, 80, 70)
        task.delay(0.3, function()
            if uiElements[remote] then
                uiElements[remote].BackgroundColor3 = method == "FireServer" and Color3.fromRGB(30, 45, 35) or Color3.fromRGB(45, 30, 35)
            end
        end)
        return
    end

    local LogItem = Instance.new("TextButton")
    LogItem.Size = UDim2.new(1, -10, 0, 32)
    LogItem.BackgroundColor3 = method == "FireServer" and Color3.fromRGB(30, 45, 35) or Color3.fromRGB(45, 30, 35)
    LogItem.Text = string.format(" [%s] %s", method:sub(1,4):upper(), tostring(remote.Name))
    LogItem.TextColor3 = Color3.fromRGB(255, 255, 255)
    LogItem.Font = Enum.Font.Arial
    LogItem.TextSize = 13
    LogItem.TextXAlignment = Enum.TextXAlignment.Left
    LogItem.Parent = ScrollingFrame
    
    uiElements[remote] = LogItem

    -- Bấm vào nút để xuất mã nguồn giả lập chi tiết ra bảng điều khiển F9 Console
    LogItem.MouseButton1Click:Connect(function()
        local data = remoteLogs[remote]
        if not data then return end
        
        print("\n=======================================================")
        print(string.format("-- GENERATED CODE SCRIPT FOR: %s", remote.Name))
        print(string.format("-- Bắt gói tin lúc [%s] | Phương thức: %s", data.time, data.method))
        print("=======================================================")
        
        -- Dựng mã nguồn khai báo đường dẫn
        print(string.format("local Remote = game:%s", remote:GetFullName():sub(6)))
        
        -- Dựng mã nguồn khai báo danh sách tham số
        print("\nlocal Arguments = {")
        if data.args and #data.args > 0 then
            for i, arg in ipairs(data.args) do
                print(string.format("    [%d] = %s,", i, formatValue(arg)))
            end
        else
            print("    -- Không có tham số truyền lên")
        end
        print("}")
        
        -- Dựng mã nguồn thực thi kích hoạt sự kiện
        print("\n-- Thực thi gửi lệnh lên Server:")
        if data.method == "FireServer" then
            print("Remote:FireServer(unpack(Arguments))")
        else
            print("local success, response = pcall(function()")
            print("    return Remote:InvokeServer(unpack(Arguments))")
            print("end)")
            print("if success then print('Phản hồi:', response) else warn('Lỗi gọi hàm:', response) end")
        end
        print("=======================================================\n")
        print("[HỆ THỐNG]: Đã sinh mã nguồn thành công. Nhấn F9 trên bàn phím để sao chép code.")
    end)
end

-- Quét tĩnh ban đầu để nạp danh sách các Remote có sẵn vào menu
task.spawn(function()
    local pathways = {game:GetService("ReplicatedStorage"), game:GetService("Workspace")}
    for _, path in ipairs(pathways) do
        pcall(function()
            for _, item in ipairs(path:GetDescendants()) do
                if item:IsA("RemoteEvent") then
                    updateRemoteUI(item, "FireServer", {})
                elseif item:IsA("RemoteFunction") then
                    updateRemoteUI(item, "InvokeServer", {})
                end
            end
        end)
    end
end)

-- Bộ lọc Metamethod __namecall thời gian thực để cập nhật tham số chính xác khi người chơi thao tác
local oldNamecall
pcall(function()
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            local args = {...}
            task.defer(updateRemoteUI, self, method, args)
        end
        return oldNamecall(self, ...)
    end)
end)

