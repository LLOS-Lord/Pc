-- KIỂM TRA MÔI TRƯỜNG
if not game:IsLoaded() then game.Loaded:Wait() end

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- =============================================
-- 1. HÀM TIỆN ÍCH
-- =============================================
local function getClosestMob(radius)
    local closest = nil
    local shortest = radius or 9999
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            if obj.Humanoid.Health > 0 and obj ~= character then
                local dist = (rootPart.Position - obj.HumanoidRootPart.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = obj
                end
            end
        end
    end
    return closest
end

local function getLootItems(radius)
    local items = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Part") and obj.Name:lower():find("loot") then
            local dist = (rootPart.Position - obj.Position).Magnitude
            if dist < (radius or 50) then
                table.insert(items, obj)
            end
        end
    end
    return items
end

-- =============================================
-- 2. AUTO FARM (TỰ ĐỘNG ĐÁNH QUÁI)
-- =============================================
local autoFarmEnabled = false
local farmRadius = 30
local attackCooldown = 0.5

local function autoFarm()
    while autoFarmEnabled do
        task.wait(0.1)
        local target = getClosestMob(farmRadius)
        if target and target:FindFirstChild("HumanoidRootPart") then
            -- Di chuyển đến mục tiêu
            humanoid:MoveTo(target.HumanoidRootPart.Position)
            
            -- Kiểm tra khoảng cách để tấn công
            local dist = (rootPart.Position - target.HumanoidRootPart.Position).Magnitude
            if dist < 8 then
                -- Sử dụng tool hiện tại để tấn công
                for _, tool in pairs(character:GetChildren()) do
                    if tool:IsA("Tool") then
                        tool:Activate()
                        task.wait(attackCooldown)
                    end
                end
            end
        end
    end
end

-- =============================================
-- 3. AUTO COLLECT (TỰ ĐỘNG NHẶT ĐỒ)
-- =============================================
local autoCollectEnabled = false
local collectRadius = 40

local function autoCollect()
    while autoCollectEnabled do
        task.wait(0.3)
        local loots = getLootItems(collectRadius)
        for _, loot in pairs(loots) do
            if loot and loot:IsA("Part") then
                -- Di chuyển đến vị trí loot
                humanoid:MoveTo(loot.Position)
                task.wait(0.1)
                -- Chạm vào loot để nhặt
                rootPart.CFrame = CFrame.new(loot.Position)
                task.wait(0.05)
            end
        end
    end
end

-- =============================================
-- 4. HITBOX EXPANSION (MỞ RỘNG HITBOX)
-- =============================================
local hitboxExpansionEnabled = false
local hitboxMultiplier = 3

local function expandHitbox()
    while hitboxExpansionEnabled do
        task.wait(0.5)
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Part") and obj.Name:lower():find("hitbox") or obj.Name:lower():find("handle") then
                local size = obj.Size
                obj.Size = Vector3.new(size.X * hitboxMultiplier, size.Y * hitboxMultiplier, size.Z * hitboxMultiplier)
            end
        end
    end
end

