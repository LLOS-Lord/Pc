-- Tầng 1: Khôi phục lại __namecall truyền thống
local oldNamecall
pcall(function()
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            task.defer(registerOrUpdateLog, self, method, {...})
        end
        return oldNamecall(self, ...)
    end)
end)

-- Tầng 2: Hook trực tiếp phương thức lưu trong __index (Giải quyết game lưu biến Local Upvalues)
local oldIndex
pcall(function()
    oldIndex = hookmetamethod(game, "__index", function(self, key)
        if key == "FireServer" or key == "InvokeServer" then
            -- Nếu script của game cố tình lấy hàm thông qua game.Remote.FireServer
            local originalFunc = oldIndex(self, key)
            return function(instance, ...)
                if instance == self then
                    task.defer(registerOrUpdateLog, self, key, {...})
                end
                return originalFunc(instance, ...)
            end
        end
        return oldIndex(self, key)
    end)
end)

-- Tầng 3: Quét động thời gian thực đề phòng các Remote sinh muộn hoặc chèn vào vùng kín
local function monitorInstance(item)
    pcall(function()
        if item:IsA("RemoteEvent") then
            -- Sử dụng kịch bản can thiệp trực tiếp vào bộ lắng nghe của chính object
            local oldFire = item.FireServer
            item.FireServer = function(self, ...)
                task.defer(registerOrUpdateLog, self, "FireServer", {...})
                return oldFire(self, ...)
            end
        elseif item:IsA("RemoteFunction") then
            local oldInvoke = item.InvokeServer
            item.InvokeServer = function(self, ...)
                task.defer(registerOrUpdateLog, self, "InvokeServer", {...})
                return oldInvoke(self, ...)
            end
        end
    end)
end

-- Kích hoạt bộ quét động trên toàn bộ các dịch vụ lưu trữ mạng mạng trong game
for _, service in ipairs({game:GetService("ReplicatedStorage"), game:GetService("Workspace"), game:GetService("JointsService")}) do
    for _, child in ipairs(service:GetDescendants()) do monitorInstance(child) end
    service.DescendantAdded:Connect(monitorInstance)
end

