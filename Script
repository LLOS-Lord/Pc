local capturedRemotes = {}
local activeUIButtons = {}

local function serializeValue(val, depth)
    depth = depth or 1
    local indent = string.rep("    ", depth)
    local t = typeof(val)
    
    if t == "string" then 
        return string.format('"%s"', val)
    elseif t == "number" or t == "boolean" then 
        return tostring(val)
    elseif t == "Vector3" then 
        return string.format("Vector3.new(%f, %f, %f)", val.X, val.Y, val.Z)
    elseif t == "Vector2" then 
        return string.format("Vector2.new(%f, %f)", val.X, val.Y)
    elseif t == "CFrame" then 
        return string.format("CFrame.new(%s)", tostring(val))
    elseif t == "Color3" then 
        return string.format("Color3.fromRGB(%d, %d, %d)", val.R*255, val.G*255, val.B*255)
    elseif t == "Instance" then 
        return "game." .. val:GetFullName()
    elseif t == "table" then
        local str = "{\n"
        for k, v in pairs(val) do
            local keyPart = typeof(k) == "number" and "" or string.format("[%s] = ", serializeValue(k, depth + 1))
            str = str .. indent .. keyPart .. serializeValue(v, depth + 1) .. ",\n"
        end
        return str .. string.rep("    ", depth - 1) .. "}"
    else 
        return "nil --[[" .. t .. "]]" 
    end
end

local function renderCodeStructure(remote, logData)
    local path = remote:GetFullName()
    local cleanPath = path:sub(1,5) == "game." and path or "game." .. path
    
    local sb = "-- MÃ NGUỒN CHUẨN ĐƯỢC TRÍCH XUẤT THỜI GIAN THỰC\n"
    sb = sb .. string.format("local TargetRemote = %s\n\n", cleanPath)
    sb = sb .. "local Args = {\n"
    
    if logData.args and #logData.args > 0 then
        for i, arg in ipairs(logData.args) do
            sb = sb .. string.format("    [%d] = %s,\n", i, serializeValue(arg, 2))
        end
    else
        sb = sb .. "    -- Không chứa tham số truyền tải\n"
    end
    sb = sb .. "}\n\n"
    
    if logData.method == "FireServer" then
        sb = sb .. "TargetRemote:FireServer(unpack(Args))\n"
    else
        sb = sb .. "local success, result = pcall(function()\n"
        sb = sb .. "    return TargetRemote:InvokeServer(unpack(Args))\n"
        sb = sb .. "end)\n\n"
        sb = sb .. "if success then\n"
        sb = sb .. "    print(\"Phản hồi từ server:\", result)\n"
        sb = sb .. "else\n"
        sb = sb .. "    warn(\"Lỗi thực thi lệnh:\", result)\n"
        sb = sb .. "end\n"
    end
    return sb
end

local function registerOrUpdateLog(remote, method, args)
    if not remote or not remote.Name then return end
    
    capturedRemotes[remote] = {
        method = method,
        args = args
    }
    
    if activeUIButtons[remote] then return end

    local LogItem = Instance.new("TextButton")
    LogItem.Size = UDim2.new(1, -10, 0, 30)
    LogItem.BackgroundColor3 = method == "FireServer" and Color3.fromRGB(32, 44, 36) or Color3.fromRGB(46, 32, 34)
    LogItem.BorderSizePixel = 0
    LogItem.Text = string.format(" [%s] %s", method:sub(1,4):upper(), tostring(remote.Name))
    LogItem.TextColor3 = Color3.fromRGB(245, 245, 245)
    LogItem.Font = Enum.Font.Arial
    LogItem.TextSize = 12
    LogItem.TextXAlignment = Enum.TextXAlignment.Left
    LogItem.Parent = ScrollingFrame
    
    activeUIButtons[remote] = LogItem

    -- Chỉ khi click vào dòng item này, khung code mới hiển thị và nạp mã
    LogItem.MouseButton1Click:Connect(function()
        local currentData = capturedRemotes[remote]
        if currentData then
            CodeTextBox.Text = renderCodeStructure(remote, currentData)
            CodeFrame.Visible = true -- Kích hoạt hiển thị khung code
        end
    end)
end

-- Hook hệ thống xử lý __namecall thời gian thực
local oldNamecall
pcall(function()
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            local args = {...}
            task.defer(registerOrUpdateLog, self, method, args)
        end
        return oldNamecall(self, ...)
    end)
end)

