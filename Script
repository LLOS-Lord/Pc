-- BLOX LOOT - HACK TỐI ƯU (FIX LỖI)
-- Phiên bản: V7.2 (Sửa auto farm, loot, fly, tele, menu toggle, respawn)
-- =============================================

if not game:IsLoaded() then game.Loaded:Wait() end

local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local userInput = game:GetService("UserInputService")

-- =============================================
-- BIẾN TOÀN CỤC
-- =============================================
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Các trạng thái
local autoFarmEnabled = false
local autoCollectEnabled = false
local hitboxExpansionEnabled = false
local multiDamageEnabled = false
local flyEnabled = false
local desyncEnabled = false
local menuVisible = true

local farmRadius = 30
local collectRadius = 40
local hitboxMultiplier = 3
local flySpeed = 50
local attackCooldown = 0.5

-- Đối tượng bay
local bodyVelocity = nil
local bodyGyro = nil
local flyConnection = nil

-- =============================================
-- HÀM TIỆN ÍCH
-- =============================================
local function isPlayerCharacter(obj)
    if not obj or not obj:IsA("Model") then return false end
    return game.Players:GetPlayerFromCharacter(obj) ~= nil
end

local function getClosestMob(radius)
    local closest = nil
    local shortest = radius or 9999
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            local hum = obj:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 and obj ~= character and not isPlayerCharacter(obj) then
                local dist = (rootPart.Position - obj.HumanoidRootPart.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = obj
                end
            end
        end
    end
    return closest
end

local function getLootItems(radius)
    local items = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        -- Tìm các Part có tên chứa "loot" hoặc "chest", hoặc có thuộc tính đặc biệt
        if obj:IsA("BasePart") and obj.Parent and obj.Parent:IsA("Model") then
            local nameLower = string.lower(obj.Name)
            if nameLower:find("loot") or nameLower:find("chest") or nameLower:find("crate") or nameLower:find("box") then
                local dist = (rootPart.Position - obj.Position).Magnitude
                if dist < (radius or 50) then
                    table.insert(items, obj)
                end
            end
        end
    end
    -- Nếu không tìm thấy, thử tìm trực tiếp trong workspace
    if #items == 0 then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and string.lower(obj.Name):find("loot") then
                local dist = (rootPart.Position - obj.Position).Magnitude
                if dist < (radius or 50) then
                    table.insert(items, obj)
                end
            end
        end
    end
    return items
end

local function updateCharacterRefs()
    character = player.Character or player.CharacterAdded:Wait()
    humanoid = character:WaitForChild("Humanoid")
    rootPart = character:WaitForChild("HumanoidRootPart")
end

-- =============================================
-- TÍNH NĂNG AUTO FARM (CHỈ NPC)
-- =============================================
local farmLoop = nil
local function startAutoFarm()
    stopAutoFarm()
    farmLoop = game:GetService("RunService").Heartbeat:Connect(function()
        if not autoFarmEnabled then return end
        local target = getClosestMob(farmRadius)
        if target and target:FindFirstChild("HumanoidRootPart") then
            humanoid:MoveTo(target.HumanoidRootPart.Position)
            local dist = (rootPart.Position - target.HumanoidRootPart.Position).Magnitude
            if dist < 8 then
                for _, tool in pairs(character:GetChildren()) do
                    if tool:IsA("Tool") then
                        tool:Activate()
                        task.wait(attackCooldown)
                    end
                end
            end
        end
    end)
end
local function stopAutoFarm()
    if farmLoop then farmLoop:Disconnect() farmLoop = nil end
end

-- =============================================
-- TÍNH NĂNG AUTO COLLECT
-- =============================================
local collectLoop = nil
local function startAutoCollect()
    stopAutoCollect()
    collectLoop = game:GetService("RunService").Heartbeat:Connect(function()
        if not autoCollectEnabled then return end
        local loots = getLootItems(collectRadius)
        for _, loot in pairs(loots) do
            if loot and loot:IsA("BasePart") then
                humanoid:MoveTo(loot.Position)
                task.wait(0.1)
                rootPart.CFrame = CFrame.new(loot.Position + Vector3.new(0, 1, 0))
                task.wait(0.05)
            end
        end
    end)
end
local function stopAutoCollect()
    if collectLoop then collectLoop:Disconnect() collectLoop = nil end
end

-- =============================================
-- HITBOX EXPANSION
-- =============================================
local hitboxLoop = nil
local function startHitbox()
    stopHitbox()
    hitboxLoop = game:GetService("RunService").Heartbeat:Connect(function()
        if not hitboxExpansionEnabled then return end
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (string.lower(obj.Name):find("hitbox") or string.lower(obj.Name):find("handle")) then
                local size = obj.Size
                obj.Size = Vector3.new(size.X * hitboxMultiplier, size.Y * hitboxMultiplier, size.Z * hitboxMultiplier)
            end
        end
    end)
end
local function stopHitbox()
    if hitboxLoop then hitboxLoop:Disconnect() hitboxLoop = nil end
end

-- =============================================
-- MULTI DAMAGE
-- =============================================
local damageLoop = nil
local function startMultiDamage()
    stopMultiDamage()
    damageLoop = game:GetService("RunService").Heartbeat:Connect(function()
        if not multiDamageEnabled then return end
        for _, tool in pairs(character:GetChildren()) do
            if tool:IsA("Tool") then
                tool:Activate()
                task.wait(0.1)
            end
        end
    end)
end
local function stopMultiDamage()
    if damageLoop then damageLoop:Disconnect() damageLoop = nil end
end

-- =============================================
-- FLY (SỬA LỖI ĐIỀU KHIỂN)
-- =============================================
local function startFly()
    if flyEnabled then return end
    flyEnabled = true
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart

    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bodyGyro.CFrame = rootPart.CFrame
    bodyGyro.Parent = rootPart

    flyConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if not flyEnabled or not bodyVelocity or not bodyGyro then return end
        local moveDir = Vector3.new(0, 0, 0)
        -- Lấy hướng camera
        local cam = workspace.CurrentCamera
        local forward = cam.CFrame.LookVector
        forward = Vector3.new(forward.X, 0, forward.Z).Unit
        local right = cam.CFrame.RightVector
        right = Vector3.new(right.X, 0, right.Z).Unit

        if userInput:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + forward end
        if userInput:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - forward end
        if userInput:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - right end
        if userInput:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + right end
        if userInput:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
        if userInput:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end

        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit * flySpeed
        end
        bodyVelocity.Velocity = moveDir
        bodyGyro.CFrame = rootPart.CFrame
    end)
end

local function stopFly()
    flyEnabled = false
    if flyConnection then flyConnection:Disconnect() flyConnection = nil end
    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
end

local function toggleFly()
    if flyEnabled then stopFly() else startFly() end
end

-- =============================================
-- DESYNC BODY
-- =============================================
local function toggleDesync()
    desyncEnabled = not desyncEnabled
    if desyncEnabled then
        character:BreakJoints()
        player.CharacterAdded:Wait()
        updateCharacterRefs()
    end
end

-- =============================================
-- TELEPORT LOOT
-- =============================================
local function teleportToLoot()
    local loots = getLootItems(200)
    if #loots > 0 then
        local targetPart = loots[1]
        if targetPart and targetPart:IsA("BasePart") then
            rootPart.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 3, 0))
        end
    end
end

