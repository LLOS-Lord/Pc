-- Hàm hiển thị log lên màn hình
local logCount = 0
local function displayLog(remote, method, args)
    if not remote or not remote.Name then return end
    logCount = logCount + 1
    
    local LogItem = Instance.new("TextButton")
    LogItem.Size = UDim2.new(1, -10, 0, 30)
    LogItem.BackgroundColor3 = (method == "FireServer" or method == "QUÉT") and Color3.fromRGB(40, 40, 50) or Color3.fromRGB(60, 40, 40)
    LogItem.Text = string.format(" [%d] [%s] -> %s", logCount, method, tostring(remote.Name))
    LogItem.TextColor3 = Color3.fromRGB(255, 255, 0) -- Chữ màu vàng để hiển thị rõ trên nền tối
    LogItem.Font = Enum.Font.Arial
    LogItem.TextSize = 13
    LogItem.TextXAlignment = Enum.TextXAlignment.Left
    LogItem.Parent = ScrollingFrame

    -- In dữ liệu cấu trúc ra bảng điều khiển F9 khi click vào dòng log
    LogItem.MouseButton1Click:Connect(function()
        print(string.format("\n--- [%s] Cấu Trúc: %s ---", method, remote:GetFullName()))
        if args and #args > 0 then
            for i, v in pairs(args) do
                print(string.format(" Tham số %s: %s (%s)", tostring(i), tostring(v), typeof(v)))
            end
        else
            print(" Không có tham số đi kèm hoặc đây là quét tĩnh.")
        end
    end)
end

-- Tính năng 1: Cưỡng ép quét toàn bộ các Remote đang ẩn trong bộ nhớ trò chơi
ScanButton.MouseButton1Click:Connect(function()
    print("[SimpleSpy] Đang tiến hành quét tĩnh hệ thống...")
    local instances = game:GetDescendants()
    for _, obj in ipairs(instances) do
        pcall(function()
            if obj:IsA("RemoteEvent") then
                displayLog(obj, "QUÉT", {})
            elseif obj:IsA("RemoteFunction") then
                displayLog(obj, "QUÉT_FUNC", {})
            end
        end)
    end
end)

-- Tính năng 2: Chặn và bắt dữ liệu gói tin thời gian thực bằng cấu trúc lồng an toàn
local oldNamecall
pcall(function()
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            local args = {...}
            task.defer(displayLog, self, method, args)
        end
        return oldNamecall(self, ...)
    end)
end)

print("[SimpleSpy] Đã khởi chạy bản sửa lỗi phông chữ hoàn tất.")
