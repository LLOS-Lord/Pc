-- 5. MULTI DAMAGE (SÁT THƯƠNG NHIỀU VŨ KHÍ)
-- =============================================
local multiDamageEnabled = false

local function multiDamage()
    while multiDamageEnabled do
        task.wait(0.2)
        -- Kích hoạt tất cả tool trong kho đồ để gây sát thương nhiều lần
        for _, tool in pairs(character:GetChildren()) do
            if tool:IsA("Tool") then
                tool:Activate()
                task.wait(0.1)
            end
        end
    end
end

