--[[
    SIMPLE SPY BYPASS V5 (SỬ DỤNG PLAYER_GUI - FIX LỖI ẨN GIAO DIỆN)
    Hỗ trợ tất cả các dòng Executor di động và máy tính (Delta, VegaX, Wave, Fluxus)
--]]

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Đợi cho đến khi PlayerGui của người chơi sẵn sàng để vẽ giao diện
if not LocalPlayer:FindFirstChild("PlayerGui") then
    local timeout = 0
    while not LocalPlayer:FindFirstChild("PlayerGui") and timeout < 5 do
        task.wait(0.5)
        timeout = timeout + 0.5
    end
end

local PlayerGui = LocalPlayer:FindFirstChild("PlayerGui")
if not PlayerGui then
    print("[Error] Không tìm thấy PlayerGui để hiển thị giao diện.")
    return
end

-- Xóa phiên bản cũ nếu đã chạy trước đó để tránh xung đột
if PlayerGui:FindFirstChild("SimpleSpy_Bypass_PlayerGui") then
    PlayerGui:FindFirstChild("SimpleSpy_Bypass_PlayerGui"):Destroy()
end

