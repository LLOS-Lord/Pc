local capturedRemotes = {}
local activeUIButtons = {}

local function serializeValue(val, depth)
    depth = depth or 1
    local indent = string.rep("    ", depth)
    local t = typeof(val)
    if t == "string" then return string.format('"%s"', val)
    elseif t == "number" or t == "boolean" then return tostring(val)
    elseif t == "Vector3" then return string.format("Vector3.new(%f, %f, %f)", val.X, val.Y, val.Z)
    elseif t == "Vector2" then return string.format("Vector2.new(%f, %f)", val.X, val.Y)
    elseif t == "CFrame" then return string.format("CFrame.new(%s)", tostring(val))
    elseif t == "Color3" then return string.format("Color3.fromRGB(%d, %d, %d)", val.R*255, val.G*255, val.B*255)
    elseif t == "Instance" then 
        local success, path = pcall(function() return "game." .. val:GetFullName() end)
        return success and path or '"[Hidden/Nil Instance]"'
    elseif t == "table" then
        local str = "{\n"
        for k, v in pairs(val) do
            local keyPart = typeof(k) == "number" and "" or string.format("[%s] = ", serializeValue(k, depth + 1))
            str = str .. indent .. keyPart .. serializeValue(v, depth + 1) .. ",\n"
        end
        return str .. string.rep("    ", depth - 1) .. "}"
    else return "nil" end
end

local function renderCodeStructure(remote, logData)
    local path = "game"
    pcall(function() path = "game." .. remote:GetFullName() end)
    local sb = "-- DEEP CAPTURED CODE\n"
    sb = sb .. string.format("local Remote = %s\n", path)
    sb = sb .. "local Args = {\n"
    if logData.args and #logData.args > 0 then
        for i, arg in ipairs(logData.args) do
            sb = sb .. string.format("    [%d] = %s,\n", i, serializeValue(arg, 2))
        end
    else
        sb = sb .. "    -- No args\n"
    end
    sb = sb .. "}\n"
    if logData.method == "FireServer" then
        sb = sb .. "Remote:FireServer(unpack(Args))"
    else
        sb = sb .. "task.spawn(function()\n    local r = Remote:InvokeServer(unpack(Args))\n    print(r)\nend)"
    end
    return sb
end

local function registerOrUpdateLog(remote, method, args)
    if not remote then return end
    local name = "Unknown_Remote"
    pcall(function() name = remote.Name end)
    
    capturedRemotes[remote] = {method = method, args = args}
    if activeUIButtons[remote] then return end

    local LogItem = Instance.new("TextButton")
    LogItem.Size = UDim2.new(1, -6, 0, 24)
    LogItem.BackgroundColor3 = method == "FireServer" and Color3.fromRGB(32, 44, 36) or Color3.fromRGB(46, 32, 34)
    LogItem.BorderSizePixel = 0
    LogItem.Text = string.format(" [%s] %s", method:sub(1,4):upper(), tostring(name))
    LogItem.TextColor3 = Color3.fromRGB(240, 240, 240)
    LogItem.Font = Enum.Font.Arial
    LogItem.TextSize = 11
    LogItem.TextXAlignment = Enum.TextXAlignment.Left
    LogItem.Parent = ScrollingFrame
    activeUIButtons[remote] = LogItem

    LogItem.MouseButton1Click:Connect(function()
        local currentData = capturedRemotes[remote]
        if currentData then
            CodeTextBox.Text = renderCodeStructure(remote, currentData)
            CodeFrame.Visible = true
        end
    end)
end

-- ========================================================
-- CƠ CHẾ CAN THIỆP SÂU VÀO ĐỐI TƯỢNG (EXTREME INSTANCE HOOK)
-- ========================================================

local hookedObjects = {}

local function deepHookRemote(object)
    if not object or hookedObjects[object] then return end
    
    local isEvent = object:IsA("RemoteEvent")
    local isFunction = object:IsA("RemoteFunction")
    
    if isEvent or isFunction then
        hookedObjects[object] = true
        
        if isEvent then
            -- Sử dụng hookfunction để can thiệp trực tiếp vào con trỏ hàm của hệ thống trò chơi
            local originalFire
            pcall(function()
                originalFire = hookfunction(object.FireServer, function(self, ...)
                    task.defer(registerOrUpdateLog, self, "FireServer", {...})
                    return originalFire(self, ...)
                end)
            end)
        elseif isFunction then
            local originalInvoke
            pcall(function()
                originalInvoke = hookfunction(object.InvokeServer, function(self, ...)
                    task.defer(registerOrUpdateLog, self, "InvokeServer", {...})
                    return originalInvoke(self, ...)
                end)
            end)
        end
    end
end

-- Quét toàn bộ đối tượng hiện có trong game và liên tục cập nhật đối tượng mới
local function runDeepScan()
    -- Cách 1: Quét theo cấu trúc phân cấp thông thường
    for _, obj in ipairs(game:GetDescendants()) do
        pcall(deepHookRemote, obj)
    end
    
    -- Cách 2: Quét trực tiếp trong Object Registry của Executor để tìm các thực thể bị ẩn danh
    if getinstances then
        for _, obj in ipairs(getinstances()) do
            pcall(deepHookRemote, obj)
        end
    elseif getnilinstances then
        for _, obj in ipairs(getnilinstances()) do
            pcall(deepHookRemote, obj)
        end
    end
end

-- Thực hiện quét liên tục để không bỏ sót các Remote tạo động theo thời gian thực
task.spawn(function()
    while true do
        pcall(runDeepScan)
        task.wait(2) -- Tự động quét lại sau mỗi 2 giây
    end
end)

-- Lắng nghe sự kiện thêm mới của game
game.DescendantAdded:Connect(function(descendant)
    pcall(deepHookRemote, descendant)
end)

